{
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    { "source": "/finance", "destination": "/financing", "permanent": true }
  ],
  "headers": [
    {
      "source": "/images/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
