{
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    { "source": "/finance", "destination": "/financing", "permanent": true }
  ],
  "rewrites": [
    { "source": "/areas/edmonton", "destination": "/edmonton" },
    { "source": "/areas/sherwood-park", "destination": "/sherwood-park" },
    { "source": "/areas/leduc", "destination": "/leduc" },
    { "source": "/areas/st-albert", "destination": "/st-albert" },
    { "source": "/areas/beaumont", "destination": "/beaumont" },
    { "source": "/areas/spruce-grove", "destination": "/spruce-grove" }
  ],
  "headers": [
    {
      "source": "/images/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
