{
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    { "source": "/finance", "destination": "/financing", "permanent": true }
  ],
  "rewrites": [
    { "source": "/areas/edmonton", "destination": "/edmonton.html" },
    { "source": "/areas/sherwood-park", "destination": "/sherwood-park.html" },
    { "source": "/areas/leduc", "destination": "/leduc.html" },
    { "source": "/areas/st-albert", "destination": "/st-albert.html" },
    { "source": "/areas/beaumont", "destination": "/beaumont.html" },
    { "source": "/areas/spruce-grove", "destination": "/spruce-grove.html" }
  ],
  "headers": [
    {
      "source": "/images/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
